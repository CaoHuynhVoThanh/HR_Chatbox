# Obtain a key from Google AI Studio, then copy this file to .env.
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-flash
# Let Gemini use Google Search when a response needs up-to-date external facts.
GEMINI_ENABLE_WEB_SEARCH=true

# Comma-separated origins for the browser client. Do not use * with credentials.
ALLOWED_ORIGINS=http://localhost:5173

# Address on which Uvicorn listens, and the address exposed to browser clients.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# Optional paths to .ttf fonts that support Vietnamese when generating the
# merged-CV PDF. Defaults are automatically detected on Windows/Linux/macOS.
# PDF_FONT_PATH=/path/to/DejaVuSans.ttf
# PDF_BOLD_FONT_PATH=/path/to/DejaVuSans-Bold.ttf
